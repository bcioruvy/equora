rules_version = '2';

// ============================================================
// EQUORA FIRESTORE SECURITY RULES
// Deploy with: firebase deploy --only firestore:rules
//
// Principle: every document a user can read or write must be
// scoped under their own uid. No cross-user reads are possible.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // ---- users/{userId} ----
    // Profile + settings document. Only the owner may read/write.
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      // ---- users/{userId}/accounts/{accountId} ----
      match /accounts/{accountId} {
        allow read, write: if isOwner(userId);
      }

      // ---- users/{userId}/transactions/{transactionId} ----
      match /transactions/{transactionId} {
        allow read, write: if isOwner(userId);
      }

      // ---- users/{userId}/budgets/{budgetId} ----
      match /budgets/{budgetId} {
        allow read, write: if isOwner(userId);
      }

      // ---- users/{userId}/goals/{goalId} ----
      match /goals/{goalId} {
        allow read, write: if isOwner(userId);
      }

      // ---- users/{userId}/notifications/{notificationId} ----
      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId);
      }

      // ---- users/{userId}/recurring/{recurringId} ----
      match /recurring/{recurringId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
